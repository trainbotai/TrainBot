+    const data = await svc.teacherUpdate({
+      ...ctx,
+      assignmentId: req.params['id'] as string,
+      ...req.body,
+    });
+    res.json(data);
+  } catch (e) { next(e); }
+}
+
+export async function teacherArchive(req: Request, res: Response, next: NextFunction) {
