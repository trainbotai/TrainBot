# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://trainbot:trainbot_dev_password@localhost:5433/trainbot_dev?schema=public

# Auth — generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=replace_me_with_64_chars_random_string_for_access_tokens_dev_only
JWT_REFRESH_SECRET=replace_me_with_DIFFERENT_64_chars_random_string_for_refresh_tokens
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Bcrypt
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
