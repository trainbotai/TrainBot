generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// MARK: - Multi-tenant root

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teachers       Teacher[]
  classes        Class[]
  llmTeacherBots LLMTeacherBot[]

  @@map("tenants")
}

enum Plan {
  FREE
  PILOT
  PAID
}

// MARK: - Teachers

model Teacher {
  id           String      @id @default(cuid())
  tenantId     String
  email        String      @unique
  passwordHash String
  name         String
  role         TeacherRole @default(TEACHER)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  lastLoginAt  DateTime?

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classes        Class[]
  refreshTokens  RefreshToken[]
  llmTeacherBots LLMTeacherBot[]

  @@index([tenantId])
  @@map("teachers")
}

enum TeacherRole {
  TEACHER
  ADMIN
}

// MARK: - Classes

model Class {
  id          String    @id @default(cuid())
  tenantId    String
  teacherId   String
  code        String    @unique
  name        String
  description String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacher        Teacher         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  students       Student[]
  assignments    Assignment[]
  llmTeacherBots LLMTeacherBot[]

  @@index([tenantId])
  @@index([teacherId])
  @@map("classes")
}

model Assignment {
  id          String              @id @default(cuid())
  tenantId    String
  classId     String
  title       String
  description String
  dueAt       DateTime?
  archivedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  type        AssignmentType    @default(ML_TRAINING)

  class       Class                  @relation(fields: [classId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]
  llmSessions LLMSession[]

  @@index([tenantId])
  @@index([classId])
  @@map("assignments")
}

model AssignmentSubmission {
  id              String   @id @default(cuid())
  assignmentId    String
  studentId       String
  mlProjectId     String?  // optional link to MLProject the student worked on
  notes           String?
  submittedAt     DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  // GDPR art. 17: la ștergerea elevului dispar și submisiile (notes = text scris de copil)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@map("assignment_submissions")
}

// MARK: - Students

model Student {
  id           String    @id @default(cuid())
  tenantId     String
  classId      String
  username     String
  passwordHash String
  displayName  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSeenAt   DateTime?

  class         Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  mlProjects    MLProject[]
  llmSessions   LLMSession[]
  llmQueries    LLMQuery[]
  llmReports    LLMReport[]
  submissions   AssignmentSubmission[]

  @@unique([classId, username])
  @@index([tenantId])
  @@map("students")
}

// MARK: - ML Projects (synced from iOS, metadata only — Phase 2A)

model MLProject {
  id           String    @id @default(cuid())
  tenantId     String
  studentId    String
  clientId     String    // UUID generated on iOS device, used for idempotent sync
  name         String
  modelTrained Boolean   @default(false)
  modelVersion Int       @default(0)
  trainedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  student Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  labels  MLLabel[]

  @@unique([studentId, clientId])
  @@index([tenantId])
  @@index([studentId])
  @@map("ml_projects")
}

model MLLabel {
  id         String   @id @default(cuid())
  projectId  String
  clientId   String   // UUID from iOS
  name       String
  imageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project MLProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  images  MLImage[]

  @@unique([projectId, clientId])
  @@index([projectId])
  @@map("ml_labels")
}

model MLImage {
  id        String   @id @default(cuid())
  labelId   String
  clientId  String   // UUID from iOS for idempotent upload
  filename  String   // path on disk relative to upload root
  sizeBytes Int
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  label MLLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([labelId, clientId])
  @@index([labelId])
  @@map("ml_images")
}

// MARK: - Refresh tokens (unified storage for teacher + student)

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  teacherId String?
  studentId String?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  teacher Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([studentId])
  @@map("refresh_tokens")
}

// MARK: - LLM Module (Phase 3A)

model LLMSession {
  id               String              @id @default(cuid())
  tenantId         String
  studentId        String
  assignmentId     String?
  name             String
  currentVersionId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?

  student          Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignment       Assignment?         @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  versions         LLMSessionVersion[]
  queries          LLMQuery[]
  reports          LLMReport[]

  @@index([tenantId])
  @@index([studentId])
  @@index([assignmentId])
  @@map("llm_sessions")
}

model LLMSessionVersion {
  id            String             @id @default(cuid())
  sessionId     String
  versionNumber Int
  examples      Json
  createdAt     DateTime           @default(now())

  session       LLMSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  queries       LLMQuery[]

  @@unique([sessionId, versionNumber])
  @@map("llm_session_versions")
}

model LLMQuery {
  id                       String            @id @default(cuid())
  sessionId                String?
  versionId                String?
  studentId                String
  botId                    String?

  userPrompt               String            @db.Text
  aiResponse               String            @db.Text

  inputModerationFlagged   Boolean           @default(false)
  outputModerationFlagged  Boolean           @default(false)
  moderationCategories     Json?

  inputTokens              Int?
  outputTokens             Int?
  groqLatencyMs            Int?

  createdAt                DateTime          @default(now())

  session                  LLMSession?       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  version                  LLMSessionVersion? @relation(fields: [versionId], references: [id])
  bot                      LLMTeacherBot?    @relation(fields: [botId], references: [id], onDelete: SetNull)
  // GDPR art. 17: query-urile către boții profesorului au sessionId null —
  // fără acest FK rămâneau orfane (cu userPrompt-ul copilului) la ștergerea elevului
  student                  Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([studentId, createdAt])
  @@index([outputModerationFlagged])
  @@index([botId])
  @@map("llm_queries")
}

model LLMReport {
  id          String      @id @default(cuid())
  sessionId   String
  studentId   String
  teacherId   String
  reason      String?
  reviewed    Boolean     @default(false)
  reviewedAt  DateTime?
  createdAt   DateTime    @default(now())

  session     LLMSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([teacherId, reviewed])
  @@map("llm_reports")
}

enum AssignmentType {
  ML_TRAINING
  LLM_TRAINING
  MIXED
}

// MARK: - LLM Teacher Demo Bots (Phase 3B)

model LLMTeacherBot {
  id          String   @id @default(cuid())
  tenantId    String
  teacherId   String
  classId     String?
  name        String
  instruction String
  examples    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacher Teacher    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class?     @relation(fields: [classId], references: [id], onDelete: SetNull)
  queries LLMQuery[]

  @@index([tenantId])
  @@index([teacherId])
  @@index([classId])
  @@map("llm_teacher_bots")
}

// MARK: - Pilot requests (lead-uri din site-ul de marketing, endpoint public)

model PilotRequest {
  id        String   @id @default(cuid())
  name      String
  school    String
  email     String
  message   String?
  locale    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("pilot_requests")
}
