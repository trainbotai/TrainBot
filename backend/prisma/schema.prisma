generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// MARK: - Multi-tenant root

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teachers Teacher[]
  classes  Class[]

  @@map("tenants")
}

enum Plan {
  FREE
  PILOT
  PAID
}

// MARK: - Teachers

model Teacher {
  id           String      @id @default(cuid())
  tenantId     String
  email        String      @unique
  passwordHash String
  name         String
  role         TeacherRole @default(TEACHER)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  lastLoginAt  DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classes       Class[]
  refreshTokens RefreshToken[]

  @@index([tenantId])
  @@map("teachers")
}

enum TeacherRole {
  TEACHER
  ADMIN
}

// MARK: - Classes

model Class {
  id          String    @id @default(cuid())
  tenantId    String
  teacherId   String
  code        String    @unique
  name        String
  description String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacher  Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  students Student[]

  @@index([tenantId])
  @@index([teacherId])
  @@map("classes")
}

// MARK: - Students

model Student {
  id           String    @id @default(cuid())
  tenantId     String
  classId      String
  username     String
  passwordHash String
  displayName  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSeenAt   DateTime?

  class         Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  mlProjects    MLProject[]

  @@unique([classId, username])
  @@index([tenantId])
  @@map("students")
}

// MARK: - ML Projects (synced from iOS, metadata only — Phase 2A)

model MLProject {
  id           String    @id @default(cuid())
  tenantId     String
  studentId    String
  clientId     String    // UUID generated on iOS device, used for idempotent sync
  name         String
  modelTrained Boolean   @default(false)
  modelVersion Int       @default(0)
  trainedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  student Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  labels  MLLabel[]

  @@unique([studentId, clientId])
  @@index([tenantId])
  @@index([studentId])
  @@map("ml_projects")
}

model MLLabel {
  id         String   @id @default(cuid())
  projectId  String
  clientId   String   // UUID from iOS
  name       String
  imageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project MLProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  images  MLImage[]

  @@unique([projectId, clientId])
  @@index([projectId])
  @@map("ml_labels")
}

model MLImage {
  id        String   @id @default(cuid())
  labelId   String
  clientId  String   // UUID from iOS for idempotent upload
  filename  String   // path on disk relative to upload root
  sizeBytes Int
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  label MLLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([labelId, clientId])
  @@index([labelId])
  @@map("ml_images")
}

// MARK: - Refresh tokens (unified storage for teacher + student)

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  teacherId String?
  studentId String?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  teacher Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([studentId])
  @@map("refresh_tokens")
}
